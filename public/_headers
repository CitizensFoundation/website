# Vite emits content-hashed JS/CSS under /assets/ — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Pre-rendered HTML has stable (unhashed) filenames; revalidate so content and
# per-page meta updates show up immediately.
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
